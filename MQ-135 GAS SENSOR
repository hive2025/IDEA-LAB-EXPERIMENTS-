/*
  MQ-135 Gas Sensor with MQUnifiedsensor Library
  
  CONNECTIONS:
  MQ-135 VCC  -> Arduino 5V
  MQ-135 GND  -> Arduino GND
  MQ-135 A0   -> Arduino Analog Pin A0
  MQ-135 D0   -> Arduino Digital Pin 2 (Optional)
*/

#include <MQUnifiedsensor.h>

// Library Setup
#define Board ("Arduino UNO")
#define Pin (A0) // Analog input
#define Type ("MQ-135")
#define Voltage_Resolution (5)
#define ADC_Bit_Resolution (10)

MQUnifiedsensor MQ135(Board, Voltage_Resolution, ADC_Bit_Resolution, Pin, Type);

void setup() {
  Serial.begin(9600);

  // Set math model to calculate the PPM based on the sensor's datasheet
  MQ135.setRegressionMethod(1); //_PPM =  a*ratio^b
  MQ135.setA(110.47); MQ135.setB(-2.862); // Parameters for CO2
  
  MQ135.init(); 
  Serial.print("Calibrating sensor...");
  MQ135.calibrate(0.21, 0.4); // Calibrate to clean air
  Serial.println(" Done!");
}

void loop() {
  MQ135.update(); // Update data from the sensor
  float ppm = MQ135.readSensor(); // Read gas concentration
  
  Serial.print("CO2 Concentration: ");
  Serial.print(ppm);
  Serial.println(" PPM");
  
  delay(1000);
}
